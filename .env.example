# =========================================
# eHorizon Business Setup Backend — Environment Variables
# =========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---- App Configuration ----
NODE_ENV=development               # development | production
PORT=3000                          # API server port
BASE_URL=https://yourdomain.com    # Public-facing URL (for redirects and download links)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com  # CORS allowed origins (comma-separated)

# ---- Database (Postgres) ----
DATABASE_URL=postgres://user:password@host:port/dbname
PGSSL=true                         # set true for Railway Postgres

# ---- Telr Payment Gateway ----
# Sign up at https://telr.com — get Store ID and Auth Key from dashboard
TELR_STORE_ID=your_store_id       # Telr Store ID
TELR_AUTH_KEY=your_auth_key       # Telr Authentication Key
TELR_TRUST_WEBHOOK=false          # Set to "true" ONLY if Telr verification API is unreliable (not recommended)

# ---- SendGrid Email ----
# Sign up at https://sendgrid.com — create an API key with "Mail Send" permission
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_TEMPLATE_ID=             # Optional: SendGrid Dynamic Template ID. If empty, uses built-in HTML template.
FROM_EMAIL=reports@yourdomain.com  # Sender email (must be verified in SendGrid)
FROM_NAME=eHorizon Business Setup Reports  # Sender display name

# ---- Download Security ----
# Used to sign download tokens for report links. Generate a random string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOWNLOAD_TOKEN_SECRET=change-me-to-a-random-64-char-hex-string

# ---- Admin Notifications ----
ADMIN_EMAIL=admin@yourdomain.com   # Admin email for failure alerts
SUPPORT_EMAIL=support@ehorizon.ae  # Customer-facing support email
CONSULTATION_URL=https://ehorizon.ae/consultation  # Link for consultant booking CTA

# ---- Future: S3/R2 Storage (Phase 2) ----
# Uncomment when adding cloud PDF storage
# S3_BUCKET=bizsetup-reports
# S3_REGION=me-south-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ---- Future: Stripe (if adding as alternative to Telr) ----
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
